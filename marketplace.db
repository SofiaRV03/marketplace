-- Tabla: carrito
CREATE TABLE IF NOT EXISTS carrito (
    id_carrito INTEGER PRIMARY KEY AUTOINCREMENT,
    id_usuario INTEGER,
    fecha_creacion DATE,
    estado VARCHAR(50) NOT NULL DEFAULT 'activo',
    FOREIGN KEY (id_usuario) REFERENCES usuario(id_usuario)
);

