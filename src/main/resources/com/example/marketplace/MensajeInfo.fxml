<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.marketplace.controller.MensajeInfoController">

    <VBox fx:id="contenedorNotificacion" alignment="CENTER" maxHeight="250.0" maxWidth="400.0" style="-fx-background-color: #d4edda; -fx-background-radius: 20; -fx-border-color: #c3e6cb; -fx-border-width: 2; -fx-border-radius: 20;">

        <padding>
            <Insets bottom="30" left="40" right="40" top="30" />
        </padding>

        <!-- Icono -->
        <Label fx:id="lblIcono" style="-fx-font-size: 48px;" text="✓" textFill="#28a745">
            <VBox.margin>
                <Insets bottom="15" />
            </VBox.margin>
        </Label>

        <!-- Título -->
        <Label fx:id="lblTitulo" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #155724;" text="¡Agregado!" textAlignment="CENTER">
            <VBox.margin>
                <Insets bottom="15" />
            </VBox.margin>
        </Label>

        <!-- Detalles del producto -->
        <VBox alignment="CENTER" spacing="8">
            <Label fx:id="lblProducto" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #155724;" text="Nombre del Producto" textAlignment="CENTER" wrapText="true" />

            <HBox alignment="CENTER" spacing="5">
                <Label fx:id="lblCantidad" style="-fx-font-size: 14px; -fx-text-fill: #155724;" text="2 unidades" />
            </HBox>
        </VBox>
          <Label fx:id="lblPrecio" style="-fx-font-size: 14px; -fx-text-fill: #155724;" text="10.000" />

        <!-- Mensaje adicional -->
        <Label fx:id="lblMensaje" style="-fx-font-size: 13px; -fx-text-fill: #155724; -fx-font-style: italic;" text="Agregado al carrito" textAlignment="CENTER" wrapText="true">
            <VBox.margin>
                <Insets top="15" />
            </VBox.margin>
        </Label>

    </VBox>

</StackPane>
