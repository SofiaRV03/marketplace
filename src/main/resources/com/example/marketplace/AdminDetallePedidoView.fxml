<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0" style="-fx-background-color: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.marketplace.controller.AdminDetallePedidoController">

    <!-- Barra superior -->
    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white;                 -fx-padding: 18 40;                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 2);">

        <HBox alignment="CENTER" spacing="10">
            <ImageView fitHeight="40" fitWidth="40" preserveRatio="true">
                <image>
                    <Image url="@images/icon.png" />
                </image>
            </ImageView>
            <Label style="-fx-font-size: 22px;                           -fx-font-weight: bold;                           -fx-text-fill: #2c3e50;" text="Gestión de Pedido" />
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <!-- Botones de navegación -->
        <HBox alignment="CENTER" spacing="12">
            <Button fx:id="btnVolverHistorial" onAction="#handleVolverHistorial" style="-fx-background-color: white; -fx-text-fill: #d98892; -fx-font-size: 13px; -fx-font-weight: 600; -fx-border-color: #d98892; -fx-border-width: 1.5; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 8 20;" text="← Volver al Historial" />

            <Button fx:id="btnVolverPanel" onAction="#handleVolverPanel" style="-fx-background-color: linear-gradient(to right, #e8a5aa, #d98892);                            -fx-text-fill: white;                            -fx-font-size: 13px;                            -fx-font-weight: bold;                            -fx-background-radius: 20;                            -fx-cursor: hand;                            -fx-padding: 8 24;                            -fx-effect: dropshadow(gaussian, rgba(217, 136, 146, 0.4), 10, 0, 0, 3);" text="🏠 Inicio" />
        </HBox>
    </HBox>

    <!-- Contenedor principal con scroll -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;                        -fx-background: transparent;                        -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="24" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="30" left="40" right="40" top="30" />
            </padding>

            <!-- Grid con 2 columnas -->
            <GridPane hgap="24" vgap="24">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50" />
                    <ColumnConstraints percentWidth="50" />
                </columnConstraints>

                <!-- Información del pedido -->
                <VBox spacing="20" style="-fx-background-color: white;                              -fx-background-radius: 16;                              -fx-padding: 30;                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" GridPane.columnIndex="0" GridPane.rowIndex="0">

                    <Label style="-fx-font-size: 18px;                                   -fx-font-weight: 700;                                   -fx-text-fill: #2c3e50;" text="📦 Información del Pedido" />

                    <Separator style="-fx-background-color: #e9ecef;" />

                    <VBox spacing="12">
                        <HBox spacing="10">
                            <Label style="-fx-font-size: 13px;                                           -fx-text-fill: #6c757d;                                           -fx-min-width: 140;" text="Número de Pedido:" />
                            <Label fx:id="lblNumeroPedido" style="-fx-font-size: 13px;                                           -fx-font-weight: 600;                                           -fx-text-fill: #2c3e50;" text="#0000" />
                        </HBox>

                        <HBox spacing="10">
                            <Label style="-fx-font-size: 13px;                                           -fx-text-fill: #6c757d;                                           -fx-min-width: 140;" text="Fecha:" />
                            <Label fx:id="lblFechaPedido" style="-fx-font-size: 13px;                                           -fx-font-weight: 600;                                           -fx-text-fill: #2c3e50;" text="--/--/----" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size: 13px;                                           -fx-text-fill: #6c757d;                                           -fx-min-width: 140;" text="Estado:" />
                            <Label fx:id="lblEstadoPedido" style="-fx-background-color: #fff3cd;                                           -fx-text-fill: #856404;                                           -fx-font-size: 12px;                                           -fx-font-weight: 600;                                           -fx-padding: 6 16;                                           -fx-background-radius: 16;" text="Pendiente" />
                        </HBox>

                        <HBox spacing="10">
                            <Label style="-fx-font-size: 13px;                                           -fx-text-fill: #6c757d;                                           -fx-min-width: 140;" text="Total:" />
                            <Label fx:id="lblTotalPedido" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #d98892;" text="0.00" />
                        </HBox>
                    </VBox>

                    <Separator style="-fx-background-color: #e9ecef;" />

                    <!-- Editor de estado -->
                    <VBox spacing="12">
                        <Label style="-fx-font-size: 14px;                                       -fx-font-weight: 600;                                       -fx-text-fill: #2c3e50;" text="✏️ Cambiar Estado del Pedido" />

                        <ComboBox fx:id="cmbEstado" maxWidth="Infinity" promptText="Seleccionar estado" style="-fx-font-size: 13px;" />

                        <Button fx:id="btnActualizarEstado" maxWidth="Infinity" onAction="#handleActualizarEstado" style="-fx-background-color: linear-gradient(to right, #e8a5aa, #d98892); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 600; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 0; -fx-effect: dropshadow(gaussian, rgba(118, 75, 162, 0.3), 8, 0, 0, 2);" text="Actualizar Estado" />
                    </VBox>
                </VBox>

                <!-- Información del usuario -->
                <VBox spacing="20" style="-fx-background-color: white;                              -fx-background-radius: 16;                              -fx-padding: 30;                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" GridPane.columnIndex="1" GridPane.rowIndex="0">

                    <Label style="-fx-font-size: 18px;                                   -fx-font-weight: 700;                                   -fx-text-fill: #2c3e50;" text="👤 Información del Cliente" />

                    <Separator style="-fx-background-color: #e9ecef;" />

                    <VBox spacing="12">
                        <HBox spacing="10">
                            <Label style="-fx-font-size: 13px;                                           -fx-text-fill: #6c757d;                                           -fx-min-width: 140;" text="ID Usuario:" />
                            <Label fx:id="lblIdUsuario" style="-fx-font-size: 13px;                                           -fx-font-weight: 600;                                           -fx-text-fill: #2c3e50;" text="0" />
                        </HBox>

                        <HBox spacing="10">
                            <Label style="-fx-font-size: 13px;                                           -fx-text-fill: #6c757d;                                           -fx-min-width: 140;" text="Nombre:" />
                            <Label fx:id="lblNombreUsuario" style="-fx-font-size: 13px;                                           -fx-font-weight: 600;                                           -fx-text-fill: #2c3e50;" text="---" wrapText="true" />
                        </HBox>

                        <HBox spacing="10">
                            <Label style="-fx-font-size: 13px;                                           -fx-text-fill: #6c757d;                                           -fx-min-width: 140;" text="Correo:" />
                            <Label fx:id="lblCorreoUsuario" style="-fx-font-size: 13px;                                           -fx-font-weight: 600;                                           -fx-text-fill: #2c3e50;" text="---" wrapText="true" />
                        </HBox>

                        <HBox spacing="10">
                            <Label style="-fx-font-size: 13px;                                           -fx-text-fill: #6c757d;                                           -fx-min-width: 140;" text="Teléfono:" />
                            <Label fx:id="lblTelefonoUsuario" style="-fx-font-size: 13px;                                           -fx-font-weight: 600;                                           -fx-text-fill: #2c3e50;" text="---" />
                        </HBox>

                        <HBox spacing="10">
                            <Label style="-fx-font-size: 13px;                                           -fx-text-fill: #6c757d;                                           -fx-min-width: 140;" text="Dirección:" />
                            <Label fx:id="lblDireccionUsuario" style="-fx-font-size: 13px;                                           -fx-font-weight: 600;                                           -fx-text-fill: #2c3e50;" text="---" wrapText="true" />
                        </HBox>
                    </VBox>
                </VBox>
            <rowConstraints>
               <RowConstraints />
            </rowConstraints>
            </GridPane>

            <!-- Lista de productos -->
            <VBox spacing="16">
                <Label style="-fx-font-size: 18px;                               -fx-font-weight: 700;                               -fx-text-fill: #2c3e50;" text="🛒 Productos del Pedido" />

                <VBox fx:id="contenedorProductos" spacing="12">
                    <!-- Los productos se cargarán dinámicamente aquí -->
                </VBox>
            </VBox>

            <!-- Resumen del pedido -->
            <VBox spacing="16" style="-fx-background-color: white;                          -fx-background-radius: 16;                          -fx-padding: 24;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">

                <Label style="-fx-font-size: 18px;                               -fx-font-weight: 700;                               -fx-text-fill: #2c3e50;" text="💰 Resumen del Pedido" />

                <Separator style="-fx-background-color: #e9ecef;" />

                <HBox alignment="CENTER_LEFT">
                    <Label style="-fx-font-size: 14px;                                   -fx-text-fill: #6c757d;" text="Subtotal:" HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblSubtotal" style="-fx-font-size: 16px;                                   -fx-font-weight: 600;                                   -fx-text-fill: #2c3e50;" text="0.00" />
                </HBox>

                <Separator style="-fx-background-color: #e9ecef;" />

                <HBox alignment="CENTER_LEFT">
                    <Label style="-fx-font-size: 18px;                                   -fx-font-weight: 700;                                   -fx-text-fill: #2c3e50;" text="Total:" HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblTotal" style="-fx-font-size: 22px; -fx-font-weight: 700; -fx-text-fill: #d98892;" text="0.00" />
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
