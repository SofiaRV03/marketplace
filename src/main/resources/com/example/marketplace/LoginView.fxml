<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.marketplace.controller.LoginController"
           style="-fx-background-color: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);">

    <!-- Contenedor principal blanco -->
    <VBox alignment="CENTER" spacing="20" maxWidth="450" maxHeight="580"
          style="-fx-background-color: white;
                 -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 40, 0, 0, 10);">
        <padding>
            <Insets top="50" right="50" bottom="50" left="50"/>
        </padding>

        <!-- Logo e ícono -->
        <VBox alignment="CENTER" spacing="12">
            <ImageView fitWidth="60" fitHeight="60" preserveRatio="true">
                <image>
                    <Image url="@images/icon.png"/>
                </image>
            </ImageView>
            <Label text="¡Bienvenido de nuevo!"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Inicia sesión para continuar comprando"
                   style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </VBox>

        <!-- Pestañas de navegación -->
        <HBox spacing="0" alignment="CENTER" style="-fx-background-color: #f8f9fa; -fx-background-radius: 8;">
            <Button text="Iniciar Sesión"
                    style="-fx-background-color: white;
                           -fx-text-fill: #2c3e50;
                           -fx-font-size: 13px;
                           -fx-font-weight: 600;
                           -fx-background-radius: 8 0 0 8;
                           -fx-padding: 10 30;
                           -fx-border-width: 0;
                           -fx-cursor: hand;"/>
            <Button text="Crear Cuenta"
                    onAction="#handleRegistro"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #7f8c8d;
                           -fx-font-size: 13px;
                           -fx-font-weight: 500;
                           -fx-background-radius: 0 8 8 0;
                           -fx-padding: 10 30;
                           -fx-border-width: 0;
                           -fx-cursor: hand;"/>
        </HBox>

        <!-- Formulario -->
        <VBox spacing="18" maxWidth="350">
            <!-- Campo Email -->
            <VBox spacing="8">
                <Label text="Correo Electrónico"
                       style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #2c3e50;"/>
                <TextField fx:id="txtCorreo"
                           promptText="tu.email@ejemplo.com"
                           style="-fx-background-color: #f8f9fa;
                                  -fx-border-color: #e9ecef;
                                  -fx-border-width: 1;
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 12 16;
                                  -fx-font-size: 14px;
                                  -fx-text-fill: #2c3e50;
                                  -fx-prompt-text-fill: #adb5bd;"/>
            </VBox>

            <!-- Campo Contraseña -->
            <VBox spacing="8">
                <Label text="Contraseña"
                       style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #2c3e50;"/>
                <PasswordField fx:id="txtContrasena"
                               promptText="••••••••"
                               style="-fx-background-color: #f8f9fa;
                                      -fx-border-color: #e9ecef;
                                      -fx-border-width: 1;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 12 16;
                                      -fx-font-size: 14px;
                                      -fx-text-fill: #2c3e50;
                                      -fx-prompt-text-fill: #adb5bd;"/>
            </VBox>

            <!-- Mensaje de error -->
            <Label fx:id="lblMensaje"
                   wrapText="true"
                   alignment="CENTER"
                   style="-fx-text-fill: #e74c3c; -fx-font-size: 12px; -fx-font-weight: 500;"/>

            <!-- Botón Login -->
            <Button fx:id="btnLogin"
                    text="Iniciar Sesión"
                    onAction="#handleLogin"
                    defaultButton="true"
                    style="-fx-background-color: linear-gradient(to right, #e8a5aa, #d98892);
                           -fx-text-fill: white;
                           -fx-font-size: 15px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-padding: 14 0;
                           -fx-pref-width: 350;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(217, 136, 146, 0.4), 12, 0, 0, 4);">
            </Button>

            <!-- Botón Volver al Catálogo -->
            <Button fx:id="btnVolverCatalogo"
                    text="← Volver al Catálogo"
                    onAction="#handleVolverCatalogo"
                    style="-fx-background-color: white;
                           -fx-text-fill: #6c757d;
                           -fx-font-size: 14px;
                           -fx-font-weight: 500;
                           -fx-border-color: #e9ecef;
                           -fx-border-width: 1.5;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-padding: 12 0;
                           -fx-pref-width: 350;">
            </Button>
        </VBox>
    </VBox>

</StackPane>