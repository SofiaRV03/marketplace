<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.marketplace.controller.MensajeCantidadController">

    <VBox alignment="CENTER" maxHeight="400" maxWidth="500" style="-fx-background-color: #f8d7da; -fx-background-radius: 20; -fx-border-radius: 20;">

        <padding>
            <Insets bottom="40" left="40" right="40" top="40" />
        </padding>

        <!-- Icono del carrito -->
        <Label style="-fx-font-size: 56px;" text="🛒" textFill="#d98892">
            <VBox.margin>
                <Insets bottom="20" />
            </VBox.margin>
        </Label>

        <!-- Título -->
        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Agregar al Carrito">
            <VBox.margin>
                <Insets bottom="15" />
            </VBox.margin>
        </Label>

        <!-- Nombre del producto -->
        <Label fx:id="lblProductoNombre" style="-fx-font-size: 18px; -fx-text-fill: #34495e; -fx-font-weight: 600;" text="Nombre del Producto" textAlignment="CENTER" wrapText="true">
            <VBox.margin>
                <Insets bottom="10" />
            </VBox.margin>
        </Label>

        <!-- Stock disponible -->
        <Label fx:id="lblStock" style="-fx-font-size: 14px; -fx-text-fill: d98892;" text="Stock disponible: 0" textFill="#d98892">
            <VBox.margin>
                <Insets bottom="25" />
            </VBox.margin>
        </Label>

        <!-- Selector de cantidad -->
        <HBox alignment="CENTER" spacing="15">
            <VBox.margin>
                <Insets bottom="30" />
            </VBox.margin>

            <Button fx:id="btnDecrementar" onAction="#handleDecrementar" onMouseEntered="#handleBtnDecMouseEntered" onMouseExited="#handleBtnDecMouseExited" style="-fx-background-color: #ecf0f1; -fx-text-fill: #2c3e50; -fx-font-size: 24px; -fx-font-weight: bold; -fx-min-width: 50; -fx-min-height: 50; -fx-background-radius: 25; -fx-cursor: hand;" text="−">
            </Button>

            <TextField fx:id="txtCantidad" alignment="CENTER" prefWidth="100" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-background-color: #f8f9fa; -fx-border-color: #e0e0e0; -fx-border-radius: 10; -fx-background-radius: 10;" text="1">
            </TextField>

            <Button fx:id="btnIncrementar" onAction="#handleIncrementar" onMouseEntered="#handleBtnIncMouseEntered" onMouseExited="#handleBtnIncMouseExited" style="-fx-background-color: d98892; -fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold; -fx-min-width: 50; -fx-min-height: 50; -fx-background-radius: 25; -fx-cursor: hand;" text="+">
            </Button>
        </HBox>

        <!-- Mensaje de error -->
        <Label fx:id="lblError" style="-fx-font-size: 13px; -fx-text-fill: #e74c3c; -fx-padding: 5;" text="" textAlignment="CENTER" visible="false" wrapText="true">
            <VBox.margin>
                <Insets bottom="15" />
            </VBox.margin>
        </Label>

        <!-- Botones de acción -->
        <HBox alignment="CENTER" spacing="15">
            <Button fx:id="btnAgregar" onAction="#handleAgregar" onMouseEntered="#handleBtnAgregarMouseEntered" onMouseExited="#handleBtnAgregarMouseExited" style="-fx-background-color: d98892; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 14 35 14 35; -fx-background-radius: 25; -fx-cursor: hand;" text="Agregar al Carrito">
            </Button>

            <Button fx:id="btnCancelar" onAction="#handleCancelar" onMouseEntered="#handleBtnCancelMouseEntered" onMouseExited="#handleBtnCancelMouseExited" style="-fx-background-color: #ecf0f1; -fx-text-fill: #7f8c8d; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 25 12 25; -fx-background-radius: 25; -fx-cursor: hand;" text="Cancelar">
            </Button>
        </HBox>

    </VBox>

</StackPane>
