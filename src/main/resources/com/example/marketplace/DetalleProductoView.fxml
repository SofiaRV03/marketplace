<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>

<VBox spacing="0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.marketplace.controller.DetalleProductoController">

    <!-- Barra superior de navegación -->
    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white; -fx-padding: 18 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 2);">

        <HBox alignment="CENTER" spacing="10">
            <ImageView fitHeight="40" fitWidth="40" preserveRatio="true">
                <image>
                    <Image url="@images/icon.png" />
                </image>
            </ImageView>
            <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Marketplace" />
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <!-- Botón volver al catálogo -->
        <Button fx:id="btnVolver" onAction="#handleVolver" style="-fx-background-color: white; -fx-text-fill: #d98892; -fx-font-size: 13px; -fx-font-weight: 600; -fx-border-color: #d98892; -fx-border-width: 1.5; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 8 20;" text="← Volver al Catálogo" />
    </HBox>

    <!-- Contenido principal con scroll -->
    <ScrollPane fx:id="scrollPaneContenido" fitToWidth="true" style="-fx-background-color: #f8f9fa; -fx-background: #f8f9fa; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">

        <VBox alignment="TOP_CENTER" style="-fx-background-color: #f8f9fa;" spacing="0">

            <padding>
                <Insets bottom="80" />
            </padding>

            <HBox alignment="CENTER" spacing="30" style="-fx-background-color: #f8f9fa; -fx-max-width: 1200;">
                <padding>
                    <Insets bottom="30" left="40" right="40" top="30" />
                </padding>

                <!-- Columna izquierda - Imagen del producto -->
                <VBox alignment="TOP_CENTER" spacing="15" style="-fx-min-width: 380; -fx-max-width: 380;">

                    <!-- Imagen principal -->
                    <StackPane style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 3); -fx-padding: 20;">
                        <ImageView fx:id="imgProducto" fitHeight="320" fitWidth="320" preserveRatio="true">
                            <image>
                                <Image url="@images/producto-placeholder.png" />
                            </image>
                        </ImageView>
                    </StackPane>

                    <!-- Miniaturas -->
                    <HBox fx:id="contenedorMiniaturas" alignment="CENTER" spacing="12">
                        <!-- Las miniaturas se agregan dinámicamente -->
                    </HBox>

                </VBox>

                <!-- Columna derecha - Información del producto -->
                <VBox spacing="18" style="-fx-min-width: 400;" HBox.hgrow="ALWAYS">

                    <!-- Nombre del producto -->
                    <VBox spacing="6">
                        <Label fx:id="lblNombre" style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #2c3e50;" text="Nombre del Producto" wrapText="true" />

                        <Label fx:id="lblId" style="-fx-font-size: 12px; -fx-text-fill: #6c757d; -fx-font-weight: 500;" text="ID: 001" />
                    </VBox>

                    <!-- Precio -->
                    <VBox spacing="4">
                        <Label fx:id="lblPrecio" style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: #d98892;" text="674.000" />
                    </VBox>

                    <!-- Línea separadora -->
                    <Line endX="350" startX="0" style="-fx-stroke: #dee2e6; -fx-stroke-width: 1;" />

                    <!-- Descripción -->
                    <VBox spacing="8">
                        <Label fx:id="lblDescripcion" style="-fx-font-size: 13px; -fx-text-fill: #495057; -fx-line-spacing: 4px;" text="Este elegante bolso bandolera es el accesorio perfecto para tu día a día..." wrapText="true" />
                    </VBox>

                    <!-- Línea separadora -->
                    <Line endX="350" startX="0" style="-fx-stroke: #dee2e6; -fx-stroke-width: 1;" />

                    <!-- Color -->
                    <VBox spacing="10">
                        <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #2c3e50;" text="Color:" />

                        <HBox fx:id="contenedorColores" spacing="8">
                            <!-- Los colores se agregan dinámicamente -->
                        </HBox>
                    </VBox>

                    <!-- Categorías -->
                    <VBox spacing="10">
                        <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #2c3e50;" text="Categorías:" />

                        <Label fx:id="lblCategorias" style="-fx-font-size: 12px; -fx-text-fill: #495057; -fx-font-weight: 500;" text="Bolsos, Accesorios" wrapText="true" />
                    </VBox>

                    <!-- Stock -->
                    <VBox spacing="10">
                        <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #2c3e50;" text="Disponibilidad:" />

                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-font-size: 14px;" text="📦" />
                            <Label fx:id="lblStock" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #155724;" text="50 unidades en stock" />
                        </HBox>
                    </VBox>

                    <!-- Línea separadora -->
                    <Line endX="350" startX="0" style="-fx-stroke: #dee2e6; -fx-stroke-width: 1;" />

                    <!-- Selector de cantidad -->
                    <VBox spacing="10">
                        <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #2c3e50;" text="Cantidad:" />

                        <HBox fx:id="contenedorCantidad" alignment="CENTER_LEFT" spacing="0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #dee2e6; -fx-border-width: 2; -fx-border-radius: 10; -fx-padding: 4; -fx-pref-width: 140; -fx-max-width: 140;">
                            <!-- Los botones y label se agregarán dinámicamente -->
                        </HBox>
                    </VBox>

                    <!-- Botón agregar al carrito -->
                    <Button fx:id="btnAgregarCarrito" onAction="#handleAgregarCarrito" maxWidth="Infinity" style="-fx-background-color: #d98892; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600; -fx-background-radius: 12; -fx-cursor: hand; -fx-padding: 14 32; -fx-effect: dropshadow(gaussian, rgba(217, 136, 146, 0.3), 12, 0, 0, 4);" text="🛒  Agregar al Carrito" />

                </VBox>

            </HBox>



        </VBox>

    </ScrollPane>

</VBox>