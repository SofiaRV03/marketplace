<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="mainContainer" spacing="0" style="-fx-background-color: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.marketplace.controller.PerfilController">

    <!-- Barra superior elegante -->
    <HBox alignment="CENTER" spacing="20" style="-fx-background-color: white; -fx-padding: 18 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 2);">

        <!-- Logo y título a la izquierda -->
        <HBox alignment="CENTER" spacing="10">
         <ImageView fitHeight="40" fitWidth="40" preserveRatio="true">
            <image>
               <Image url="@images/icon.png" />
            </image>
         </ImageView>
            <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Perfil" />
        </HBox>

        <!-- Espaciador flexible -->
        <Region HBox.hgrow="ALWAYS" />

        <!-- Info del usuario y botón volver a la derecha -->
        <HBox alignment="CENTER" spacing="12">
            <StackPane style="-fx-background-color: #f8d7da; -fx-background-radius: 20; -fx-pref-width: 36; -fx-pref-height: 36;">
                <Label style="-fx-font-size: 18px;" text="👤" />
            </StackPane>

            <VBox alignment="CENTER_LEFT" spacing="2">
                <Label style="-fx-font-size: 10px; -fx-text-fill: #6c757d;" text="Usuario" />
                <Label fx:id="lblUsuario" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #2c3e50;" text="Usuario" />
            </VBox>

            <Button fx:id="btnVolverCatalogo" onAction="#volverCatalogo" style="-fx-background-color: linear-gradient(to right, #e8a5aa, #d98892); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 600; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 8 20; -fx-effect: dropshadow(gaussian, rgba(217, 136, 146, 0.4), 10, 0, 0, 3);" text="← Volver al Catálogo" />
        </HBox>
    </HBox>

    <!-- Contenido principal con scroll -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="30" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="30" left="50" right="50" top="30" />
            </padding>

            <!-- Título Principal -->
            <Label style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Mi Perfil" />

            <!-- Contenedor Principal con 2 columnas -->
            <HBox alignment="TOP_CENTER" spacing="30">

                <!-- Columna 1: Información Personal -->
                <VBox maxWidth="500" spacing="20" style="-fx-background-color: white; -fx-padding: 30; -fx-border-radius: 10; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-padding: 0 0 10 0;" text="Información Personal" />

                    <VBox spacing="8">
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-font-weight: 600;" text="Nombre Completo" />
                        <TextField fx:id="txtNombre" promptText="Ingresa tu nombre" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 12 15; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" />
                    </VBox>

                    <VBox spacing="8">
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-font-weight: 600;" text="Correo Electrónico" />
                        <TextField fx:id="txtCorreo" promptText="correo@ejemplo.com" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 12 15; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" />
                    </VBox>

                    <VBox spacing="8">
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-font-weight: 600;" text="Dirección de Envío" />
                        <TextField fx:id="txtDireccion" promptText="Calle, número, colonia" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 12 15; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" />
                    </VBox>

                    <VBox spacing="8">
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-font-weight: 600;" text="Teléfono" />
                        <TextField fx:id="txtTelefono" promptText="Número de contacto" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 12 15; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" />
                    </VBox>

                    <Button fx:id="btnGuardarCambios" onAction="#guardarCambios" style="-fx-background-color: linear-gradient(to right, #e8a5aa, #d98892); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 12 30; -fx-border-radius: 8; -fx-background-radius: 8; -fx-min-width: 200; -fx-effect: dropshadow(gaussian, rgba(217, 136, 146, 0.4), 10, 0, 0, 3);" text="Guardar Cambios" />
                </VBox>

                <!-- Columna 2: Gestión de Contraseña -->
                <VBox maxWidth="500" spacing="20" style="-fx-background-color: white; -fx-padding: 30; -fx-border-radius: 10; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-padding: 0 0 10 0;" text="Gestión de Contraseña" />

                    <VBox spacing="8">
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-font-weight: 600;" text="Contraseña Actual" />
                        <PasswordField fx:id="txtContrasenaActual" promptText="Introduce tu contraseña actual" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 12 15; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" />
                    </VBox>

                    <VBox spacing="8">
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-font-weight: 600;" text="Nueva Contraseña" />
                        <PasswordField fx:id="txtNuevaContrasena" promptText="Mínimo 6 caracteres" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 12 15; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" />
                        <Label fx:id="lblValidacionContrasena" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-padding: 2 0 0 0;" text="La contraseña debe tener al menos 6 caracteres" />
                    </VBox>

                    <VBox spacing="8">
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-font-weight: 600;" text="Confirmar Nueva Contraseña" />
                        <PasswordField fx:id="txtConfirmarContrasena" promptText="Confirma tu nueva contraseña" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 12 15; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" />
                    </VBox>

                    <Button fx:id="btnCambiarContrasena" onAction="#cambiarContrasena" style="-fx-background-color: linear-gradient(to right, #e8a5aa, #d98892); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 12 30; -fx-border-radius: 8; -fx-background-radius: 8; -fx-min-width: 200; -fx-effect: dropshadow(gaussian, rgba(217, 136, 146, 0.4), 10, 0, 0, 3);" text="Cambiar Contraseña" />
                </VBox>

            </HBox>

            <!-- Botón Volver al Catálogo -->
            <HBox alignment="CENTER" spacing="10" />

        </VBox>
    </ScrollPane>

</VBox>
