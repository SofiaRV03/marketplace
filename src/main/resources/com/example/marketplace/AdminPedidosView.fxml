<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0" style="-fx-background-color: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.marketplace.controller.AdminPedidosController">

    <!-- Barra superior -->
    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white;                 -fx-padding: 18 40;                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 2);">

        <HBox alignment="CENTER" spacing="10">
            <ImageView fitHeight="40" fitWidth="40" preserveRatio="true">
                <image>
                    <Image url="@images/icon.png" />
                </image>
            </ImageView>
            <Label style="-fx-font-size: 22px;                           -fx-font-weight: bold;                           -fx-text-fill: #2c3e50;" text="Gestión de Pedidos" />
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <!-- Info del administrador -->
        <HBox alignment="CENTER" spacing="12">
            <StackPane style="-fx-background-color: #d1e7dd; -fx-background-radius: 20; -fx-pref-width: 36; -fx-pref-height: 36;">
                <Label style="-fx-font-size: 18px;" text="👨‍💼" />
            </StackPane>

            <VBox alignment="CENTER_LEFT" spacing="2">
                <Label style="-fx-font-size: 10px; -fx-text-fill: #6c757d;" text="Administrador" />
                <Label fx:id="lblAdministrador" style="-fx-font-size: 13px;                               -fx-font-weight: 600;                               -fx-text-fill: #2c3e50;" text="Admin" />
            </VBox>

            <Button fx:id="btnVolverPanel" onAction="#handleVolverPanel" style="-fx-background-color: linear-gradient(to right, #e8a5aa, #d98892); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 8 24; -fx-effect: dropshadow(gaussian, rgba(118, 75, 162, 0.4), 10, 0, 0, 3);" text="Inicio" />
        </HBox>
    </HBox>

    <!-- Contenedor principal con scroll -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;                        -fx-background: transparent;                        -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="20" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="30" left="40" right="40" top="30" />
            </padding>

            <!-- Header con estadísticas -->
            <VBox alignment="CENTER_LEFT" spacing="8">
                <Label style="-fx-font-size: 28px;                               -fx-font-weight: 700;                               -fx-text-fill: #2c3e50;" text="Todos los Pedidos" />
                <Label fx:id="lblCantidadPedidos" style="-fx-font-size: 14px;                               -fx-text-fill: #6c757d;" text="0 pedidos registrados" />
            </VBox>

            <!-- Panel de búsqueda y filtros -->
            <HBox alignment="CENTER_LEFT" spacing="20">
                <!-- Buscador -->
                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white;                          -fx-background-radius: 25;                          -fx-padding: 12 20;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 16px;" text="🔍" />
                    <TextField fx:id="txtBuscarUsuario" promptText="Buscar por nombre o ID de usuario..." style="-fx-background-color: transparent;                           -fx-border-color: transparent;                           -fx-font-size: 14px;                           -fx-prompt-text-fill: #adb5bd;" HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Botón refrescar -->
                <Button fx:id="btnRefrescar" onAction="#handleRefrescar" style="-fx-background-color: white;                                -fx-text-fill: #495057;                                -fx-font-size: 13px;                                -fx-font-weight: 600;                                -fx-background-radius: 20;                                -fx-cursor: hand;                                -fx-padding: 10 20;                                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" text="🔄 Actualizar" />
            </HBox>

            <!-- Panel de filtros por estado -->
            <VBox spacing="16" style="-fx-background-color: white;                          -fx-background-radius: 16;                          -fx-padding: 24;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">

                <HBox alignment="CENTER" spacing="10">
                    <ToggleButton fx:id="btnTodos" selected="true" style="-fx-font-size: 12px;                                          -fx-font-weight: 600;                                          -fx-background-radius: 16;                                          -fx-cursor: hand;                                          -fx-padding: 8 20;" text="Todos" />

                    <ToggleButton fx:id="btnPendiente" style="-fx-font-size: 12px;                                          -fx-font-weight: 600;                                          -fx-background-radius: 16;                                          -fx-cursor: hand;                                          -fx-padding: 8 20;" text="⏳ Pendiente" />

                    <ToggleButton fx:id="btnProcesando" style="-fx-font-size: 12px;                                          -fx-font-weight: 600;                                          -fx-background-radius: 16;                                          -fx-cursor: hand;                                          -fx-padding: 8 20;" text="📦 Procesando" />

                    <ToggleButton fx:id="btnEnviado" style="-fx-font-size: 12px;                                          -fx-font-weight: 600;                                          -fx-background-radius: 16;                                          -fx-cursor: hand;                                          -fx-padding: 8 20;" text="🚚 Enviado" />

                    <ToggleButton fx:id="btnEntregado" style="-fx-font-size: 12px;                                          -fx-font-weight: 600;                                          -fx-background-radius: 16;                                          -fx-cursor: hand;                                          -fx-padding: 8 20;" text="✅ Entregado" />
                </HBox>
            </VBox>

            <!-- Contenedor de pedidos -->
            <VBox fx:id="contenedorPedidos" spacing="16">
                <!-- Los pedidos se cargarán dinámicamente aquí -->
            </VBox>

            <!-- Mensaje cuando no hay pedidos -->
            <VBox fx:id="mensajeSinPedidos" alignment="CENTER" managed="false" spacing="20" style="-fx-background-color: white;                          -fx-background-radius: 16;                          -fx-padding: 60 40;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" visible="false">

                <Label style="-fx-font-size: 64px;" text="📦" />

                <VBox alignment="CENTER" spacing="8">
                    <Label style="-fx-font-size: 24px;                                   -fx-font-weight: 700;                                   -fx-text-fill: #2c3e50;" text="No se encontraron pedidos" />
                    <Label style="-fx-font-size: 14px;                                   -fx-text-fill: #6c757d;" text="No hay pedidos que coincidan con los filtros seleccionados" />
                </VBox>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
